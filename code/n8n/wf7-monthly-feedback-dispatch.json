    {
      "parameters": {
        "jsCode": "const results = [];\nconst relResponses = $input.all();\nconst seniors = $('Extract Seniors').all();\nfor (let i = 0; i < relResponses.length; i++) {\n  const senior = seniors[i]?.json || {};\n  const rels = relResponses[i].json.results || [];\n  for (const rel of rels) {\n    const personArr = rel.related_person || [];\n    for (const p of personArr) {\n      results.push({ json: {\n        person_id: p.id,\n        senior_name: senior.senior_name,\n      }});\n    }\n  }\n}\nreturn results;"
