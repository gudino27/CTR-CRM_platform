      "id": "n2",
      "name": "Get Active Seniors",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        432,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "const results = [];\nconst seniors = $input.first().json.results || [];\nfor (const s of seniors) {\n  results.push({ json: {\n    senior_id: s.id,\n    senior_name: s.display_name || s.Name || ('Senior #' + s.id),\n  }});\n}\nreturn results;"
      },
      "id": "n3",
      "name": "Extract Seniors",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        656,
        304
      ]
    },
    {
      "parameters": {
        "url": "=https://baserow.conversationstoremember.org/api/database/rows/table/563/?user_field_names=true&filters={\"filter_type\":\"AND\",\"filters\":[{\"field\":\"senior\",\"type\":\"link_row_has\",\"value\":\"{{ $json.senior_id }}\"},{\"field\":\"status\",\"type\":\"single_select_equal\",\"value\":\"active\"}]}&size=100",
