      },
      "id": "n4a",
      "name": "Get Volunteer Teams",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        880,
        208
      ]
    },
    {
      "parameters": {
        "jsCode": "const results = [];\nconst teamResponses = $input.all();\nconst seniors = $('Extract Seniors').all();\nfor (let i = 0; i < teamResponses.length; i++) {\n  const senior = seniors[i]?.json || {};\n  const teams = teamResponses[i].json.results || [];\n  for (const team of teams) {\n    results.push({ json: {\n      team_id: team.id,\n      senior_id: senior.senior_id,\n      senior_name: senior.senior_name,\n    }});\n  }\n}\nreturn results;"
      },
      "id": "n5a",
      "name": "Extract Teams",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1104,
        208
      ]
    },
    {
      "parameters": {
        "url": "=https://baserow.conversationstoremember.org/api/database/rows/table/564/?user_field_names=true&filters={\"filter_type\":\"AND\",\"filters\":[{\"field\":\"team\",\"type\":\"link_row_has\",\"value\":\"{{ $json.team_id }}\"},{\"field\":\"end_date\",\"type\":\"empty\",\"value\":\"\"}]}&size=200",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Token BHV3LDvlpFHIwdrNXOB09ddaW3qb6yNp"
            }
          ]
        },
        "options": {}
      },
      "id": "n6a",
      "name": "Get Active Members",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1328,
        208
      ]
    },
    {
      "parameters": {
        "jsCode": "const results = [];\nconst memberResponses = $input.all();\nconst teams = $('Extract Teams').all();\nfor (let i = 0; i < memberResponses.length; i++) {\n  const ctx = teams[i]?.json || {};\n  const members = memberResponses[i].json.results || [];\n  for (const m of members) {\n    const volArr = m.volunteer || [];\n    for (const v of volArr) {\n      results.push({ json: {\n        volunteer_id: v.id,\n        senior_id: ctx.senior_id,\n        senior_name: ctx.senior_name,\n      }});\n    }\n  }\n}\nreturn results;"
      },
