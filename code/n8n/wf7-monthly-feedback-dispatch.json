      "id": "n9a",
      "name": "Get Volunteer Person",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2000,
        208
      ]
    },
    {
      "parameters": {
        "jsCode": "const results = [];\nconst persons = $input.all();\nconst members = $('Split Members').all();\nfor (let i = 0; i < persons.length; i++) {\n  const person = persons[i].json;\n  const member = members[i]?.json || {};\n  results.push({ json: {\n    to: person.email,\n    first_name: person.first_name || 'Volunteer',\n    senior_name: member.senior_name,\n    form_url: 'https://baserow.conversationstoremember.org/form/volunteer-monthly-PLACEHOLDER',\n  }});\n}\nreturn results;"
      },
