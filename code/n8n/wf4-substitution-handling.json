    {
      "name": "Parse Attendance",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        300
      ],
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst items = body.items || [];\nconst oldItems = body.old_items || [];\n\nconst item = items[0] || {};\nconst oldItem = oldItems[0] || {};\n\nconst attendanceId      = item.id;\nconst meetingInstanceId = (item.meeting_instance || [])[0]?.id;\nconst volunteerId       = (item.volunteer || [])[0]?.id;\nconst newStatus         = item.attendance_status?.value || item.attendance_status || '';\nconst oldStatus         = oldItem.attendance_status?.value || oldItem.attendance_status || '';\n\nreturn [{ json: { attendanceId, meetingInstanceId, volunteerId, newStatus, oldStatus } }];"
      },
      "id": "0b99120d-506f-46fd-bda4-2ef4f2339530"
    },
