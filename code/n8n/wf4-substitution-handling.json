        "url": "=https://www.googleapis.com/calendar/v3/calendars/{{ encodeURIComponent($('Build Sub Calendar Patch').item.json.calendarId) }}/events/{{ $('Build Sub Calendar Patch').item.json.calEventId }}/instances?timeMin={{ encodeURIComponent($json.timeMin) }}&timeMax={{ encodeURIComponent($json.timeMax) }}&maxResults=5",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleCalendarOAuth2Api",
        "options": {}
      },
      "credentials": {
        "googleCalendarOAuth2Api": {
          "id": "swQQbJOZ8pjWMSfx",
