    {
      "name": "Build Sub Calendar Patch",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1680,
        300
      ],
      "parameters": {
        "jsCode": "const meeting  = $('Get Meeting').item.json;\nconst instance = $('Get Meeting Instance').item.json;\nconst subPerson = $input.first().json;\n\nconst subEmail   = subPerson.email || '';\nconst subName    = subPerson.Name || ((subPerson.first_name || '') + ' ' + (subPerson.last_name || '')).trim();\nconst meetingLink = meeting.meeting_link || '';\nconst calendarId  = meeting.google_calendar_id || 'e8a07748b896cc2ae78ce0296041d68cefed0c89d9e0cd4ec15b4fa42eae1756@group.calendar.google.com';\nconst calEventId  = meeting.calendar_event_id || '';\n\n// Use instance_date (YYYY-MM-DD) to build a full-day UTC window\n// This avoids timezone offset mismatches when querying Google Calendar instances\nconst instanceDate = instance.instance_date || instance.instance_start?.split('T')[0] || '';\nif (!instanceDate) throw new Error('No instance_date on meeting instance row');\n\nconst timeMin = instanceDate + 'T00:00:00Z';\nconst timeMax = instanceDate + 'T23:59:59Z';\n\nreturn [{ json: { calendarId, calEventId, subEmail, subName, meetingLink, timeMin, timeMax } }];"
      },
      "id": "2839f498-5dc8-438a-a13b-1ff7f0ccc174"
    },
