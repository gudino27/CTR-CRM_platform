    {
      "parameters": {
        "jsCode": "const results = [];\nconst personResponses = $input.all();\nconst ctxItems = $('Extract Person ID').all();\nconst instanceDate = $('Extract Instance').first().json.instance_date || '';\nfor (let i = 0; i < personResponses.length; i++) {\n  const person = personResponses[i].json;\n  const ctx = ctxItems[i]?.json || {};\n  if (!person.email) continue;\n  results.push({ json: {\n    toEmail: person.email,\n    firstName: person.first_name || ctx.volunteer_name,\n    instanceDate: instanceDate,\n  }});\n}\nreturn results;\n"
      },
