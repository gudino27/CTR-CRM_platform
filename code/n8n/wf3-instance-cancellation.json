    {
      "parameters": {
        "jsCode": "const results = [];\nconst rows = ($input.first().json.results || []);\nfor (const att of rows) {\n  const volArr = att.volunteer || [];\n  for (const vol of volArr) {\n    results.push({ json: { volunteer_id: vol.id, volunteer_name: vol.value } });\n  }\n}\nreturn results;\n"
