    {
      "parameters": {
        "jsCode": "const results = [];\nconst volResponses = $input.all();\nconst ctxItems = $('Split Attendees').all();\nfor (let i = 0; i < volResponses.length; i++) {\n  const vol = volResponses[i].json;\n  const ctx = ctxItems[i]?.json || {};\n  const personArr = vol.person || [];\n  const personId = personArr[0]?.id;\n  results.push({ json: { person_id: personId, volunteer_name: ctx.volunteer_name } });\n}\nreturn results;\n"
